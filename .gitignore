# ============================================================
#  .gitignore — Python Project
# ============================================================


# ------------------------------------------------------------
# 🔐 Variáveis de Ambiente & Segredos
# ------------------------------------------------------------
.env
.env.*
!.env.example          # mantém o template de exemplo no repo
*.pem
*.key
secrets.json
secrets.yaml
secrets.yml


# ------------------------------------------------------------
# 🐍 Python
# ------------------------------------------------------------

# Bytecode
__pycache__/
*.py[cod]
*$py.class

# Distribuição / Empacotamento
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
develop-eggs/
.installed.cfg
lib/
lib64/
wheels/
share/python-wheels/
MANIFEST

# Instalador
pip-log.txt
pip-delete-this-directory.txt


# ------------------------------------------------------------
# 🧪 Testes & Cobertura
# ------------------------------------------------------------
.tox/
.nox/
.coverage
.coverage.*
coverage.xml
*.cover
*.py,cover
htmlcov/
.hypothesis/
.pytest_cache/
nosetests.xml
test-results/


# ------------------------------------------------------------
# 📦 Ambientes Virtuais
# ------------------------------------------------------------
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/
.virtualenv/
.conda/
conda-env/
Pipfile.lock          # opcional — remova esta linha se quiser versionar


# ------------------------------------------------------------
# 🛠️ Ferramentas de Build & Type Checking
# ------------------------------------------------------------
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/
.ruff_cache/
pyrightconfig.json


# ------------------------------------------------------------
# 📓 Jupyter Notebook
# ------------------------------------------------------------
.ipynb_checkpoints/
*.ipynb_checkpoints
profile_default/
ipython_config.py


# ------------------------------------------------------------
# 📊 Dados & Modelos (comum em projetos ML/Data)
# ------------------------------------------------------------
*.csv
*.parquet
*.sqlite
*.db
*.h5
*.pkl
*.pickle
*.joblib
data/raw/
data/processed/
models/
checkpoints/


# ------------------------------------------------------------
# 🗃️ Logs & Arquivos Temporários
# ------------------------------------------------------------
*.log
*.tmp
*.temp
*.bak
*.swp
*.swo
logs/
tmp/


# ------------------------------------------------------------
# 💻 IDEs & Editores
# ------------------------------------------------------------

# VS Code
.vscode/
!.vscode/extensions.json   # mantém recomendações de extensões

# PyCharm / JetBrains
.idea/
*.iml

# Vim / Neovim
*.swp
*.swo
Session.vim
.netrwhist

# Sublime Text
*.sublime-workspace

# Spyder
.spyderproject.cfg
.spyproject/

# Rope
.ropeproject/


# ------------------------------------------------------------
# 🍎 macOS
# ------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes


# ------------------------------------------------------------
# 🪟 Windows
# ------------------------------------------------------------
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/


# ------------------------------------------------------------
# 🐧 Linux
# ------------------------------------------------------------
*~


# ------------------------------------------------------------
# ☁️ Deploy & Infraestrutura
# ------------------------------------------------------------
.terraform/
*.tfstate
*.tfstate.backup
.serverless/
.chalice/deployments/
*.zip                 # artefatos de deploy
